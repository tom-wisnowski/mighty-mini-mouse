# Top-level EditorConfig
root = true

# ── All files ──
[*]
indent_style = space
indent_size = 4
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{json,xml,yml,yaml,csproj,props}]
indent_size = 2

# ── C# files ──
[*.cs]

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  Built-in .NET SDK Analyzers (CA rules)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# -- Security rules: keep these as warnings --
dotnet_diagnostic.CA2100.severity = warning   # SQL injection
dotnet_diagnostic.CA2300.severity = warning   # Insecure deserializer
dotnet_diagnostic.CA2301.severity = warning   # Insecure deserializer
dotnet_diagnostic.CA2302.severity = warning   # Insecure deserializer
dotnet_diagnostic.CA2305.severity = warning   # Insecure deserializer
dotnet_diagnostic.CA2310.severity = warning   # Insecure deserializer
dotnet_diagnostic.CA2311.severity = warning   # Insecure deserializer
dotnet_diagnostic.CA2312.severity = warning   # Insecure deserializer
dotnet_diagnostic.CA2315.severity = warning   # Insecure deserializer
dotnet_diagnostic.CA2321.severity = warning   # Insecure deserializer
dotnet_diagnostic.CA2322.severity = warning   # Insecure deserializer
dotnet_diagnostic.CA5350.severity = warning   # Weak crypto
dotnet_diagnostic.CA5351.severity = warning   # Broken crypto
dotnet_diagnostic.CA5359.severity = warning   # Do not disable cert validation
dotnet_diagnostic.CA5360.severity = warning   # Dangerous deserialization
dotnet_diagnostic.CA5364.severity = warning   # Deprecated security protocols

# -- P/Invoke & Interop: suppress modernization noise --
# This app deliberately uses DllImport, not LibraryImport.
# Win32 struct names (RAWINPUT, MSLLHOOKSTRUCT etc.) are kept ALL_CAPS to match Win32 documentation.
dotnet_diagnostic.SYSLIB1054.severity = none  # Use LibraryImport instead of DllImport
dotnet_diagnostic.CA1401.severity = none      # P/Invokes should not be visible (we use internal)
dotnet_diagnostic.CA2101.severity = suggestion # Specify marshaling for P/Invoke string args
dotnet_diagnostic.CA1806.severity = suggestion # P/Invoke calls that ignore HRESULT
dotnet_diagnostic.CA2020.severity = suggestion # IntPtr explicit conversion (x64 safe)

# -- Performance: keep as suggestions (informational) --
dotnet_diagnostic.CA1805.severity = suggestion # Default value initialization
dotnet_diagnostic.CA1822.severity = suggestion # Mark members as static
dotnet_diagnostic.CA1852.severity = suggestion # Seal internal types
dotnet_diagnostic.CA1859.severity = suggestion # Use concrete types for perf
dotnet_diagnostic.CA1860.severity = suggestion # Avoid Using Enumerable.Any() extension method
dotnet_diagnostic.CA1861.severity = suggestion # Avoid constant arrays as arguments
dotnet_diagnostic.CA1862.severity = suggestion # Use StringComparison overloads
dotnet_diagnostic.CA1866.severity = suggestion # Use char overload of StartsWith/EndsWith

# -- Design rules --
dotnet_diagnostic.CA1031.severity = suggestion # Do not catch general exception type
dotnet_diagnostic.CA1034.severity = suggestion # Nested types should not be visible
dotnet_diagnostic.CA1051.severity = suggestion # Do not declare visible instance fields
dotnet_diagnostic.CA1052.severity = suggestion # Seal internal types
dotnet_diagnostic.CA1062.severity = none       # Validate arguments of public methods (nullable covers this)
dotnet_diagnostic.CA1303.severity = none       # Do not pass literals as localized parameters
dotnet_diagnostic.CA1816.severity = suggestion # Call GC.SuppressFinalize correctly
dotnet_diagnostic.CA2201.severity = suggestion # Do not raise reserved exception types

# -- Naming rules: suggestions only --
dotnet_diagnostic.CA1707.severity = suggestion # Identifiers should not contain underscores
dotnet_diagnostic.CA1708.severity = suggestion # Identifiers should differ by more than case
dotnet_diagnostic.CA1710.severity = suggestion # Identifiers should have correct suffix
dotnet_diagnostic.CA1711.severity = suggestion # Identifiers should not have incorrect suffix
dotnet_diagnostic.CA1720.severity = suggestion # Identifiers should not contain type names
dotnet_diagnostic.CA1724.severity = suggestion # Type names should not match namespaces

# -- Globalization: not needed for a desktop-only Windows app --
dotnet_diagnostic.CA1304.severity = none       # Specify CultureInfo
dotnet_diagnostic.CA1305.severity = none       # Specify IFormatProvider
dotnet_diagnostic.CA1307.severity = none       # Specify StringComparison for clarity
dotnet_diagnostic.CA1309.severity = none       # Use ordinal string comparison
dotnet_diagnostic.CA1310.severity = none       # Specify StringComparison for correctness

# -- Reliability --
# CA2000/CA2213: WinForms controls are disposed by their parent container; these fire
# heavily on dialog classes but are mostly false positives in this context.
dotnet_diagnostic.CA2000.severity = suggestion # Dispose objects before losing scope
dotnet_diagnostic.CA2007.severity = none       # Consider calling ConfigureAwait (not needed in WinForms)
dotnet_diagnostic.CA2213.severity = suggestion # Disposable fields should be disposed
dotnet_diagnostic.CA2214.severity = warning    # Do not call overridable methods in constructors

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  Roslynator (RCS rules)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

dotnet_diagnostic.RCS1018.severity = suggestion  # Add accessibility modifiers
dotnet_diagnostic.RCS1037.severity = suggestion  # Remove trailing whitespace
dotnet_diagnostic.RCS1036.severity = suggestion  # Remove unnecessary blank line
dotnet_diagnostic.RCS1021.severity = suggestion  # Convert lambda expression body to expression-body
dotnet_diagnostic.RCS1085.severity = suggestion  # Use auto-implemented property
dotnet_diagnostic.RCS1102.severity = suggestion  # Make class static
dotnet_diagnostic.RCS1118.severity = suggestion  # Mark local variable as const
dotnet_diagnostic.RCS1163.severity = suggestion  # Unused parameter
dotnet_diagnostic.RCS1194.severity = suggestion  # Implement exception constructors
dotnet_diagnostic.RCS1197.severity = suggestion  # Optimize StringBuilder.Append methods

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  Meziantou.Analyzer (MA rules)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

dotnet_diagnostic.MA0002.severity = none       # IEqualityComparer<string> — globalization noise
dotnet_diagnostic.MA0004.severity = none       # ConfigureAwait — not needed in WinForms context
dotnet_diagnostic.MA0006.severity = suggestion # Use string.Equals instead of ==
dotnet_diagnostic.MA0009.severity = suggestion # Regex DoS — review regex patterns
dotnet_diagnostic.MA0011.severity = none       # IFormatProvider (same as CA1305)
dotnet_diagnostic.MA0015.severity = suggestion # Specify the parameter name in ArgumentException
dotnet_diagnostic.MA0016.severity = suggestion # Prefer collection abstraction over implementation
dotnet_diagnostic.MA0023.severity = suggestion # Add RegexOptions.ExplicitCapture
dotnet_diagnostic.MA0025.severity = suggestion # Implement the functionality instead of throwing NotImplementedException
dotnet_diagnostic.MA0026.severity = suggestion # Fix TODO comments
dotnet_diagnostic.MA0028.severity = suggestion # Optimize StringBuilder usage
dotnet_diagnostic.MA0046.severity = suggestion # Delegate signature in events
dotnet_diagnostic.MA0048.severity = suggestion # File name must match type name
dotnet_diagnostic.MA0049.severity = suggestion # Type name should not match containing namespace
dotnet_diagnostic.MA0051.severity = suggestion # Method is too long
dotnet_diagnostic.MA0056.severity = suggestion # Do not call overridable members in constructor
dotnet_diagnostic.MA0074.severity = suggestion # Use StringComparison overload
dotnet_diagnostic.MA0076.severity = none       # Do not use implicit culture-sensitive ToString
dotnet_diagnostic.MA0099.severity = suggestion # Use explicit enum value instead of 0
dotnet_diagnostic.MA0134.severity = suggestion # Observe result of async calls
dotnet_diagnostic.MA0147.severity = suggestion # Avoid async void for delegates

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  SonarAnalyzer (S rules) — security & quality
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# S101: Win32 struct names are deliberately ALL_CAPS to match platform documentation
dotnet_diagnostic.S101.severity = none           # Type naming conventions (suppressed for P/Invoke structs)
dotnet_diagnostic.S1066.severity = suggestion    # Merge if statements
dotnet_diagnostic.S1075.severity = suggestion    # Refactor hardcoded URI
dotnet_diagnostic.S1118.severity = suggestion    # Add protected ctor or static keyword
dotnet_diagnostic.S1135.severity = suggestion    # Track uses of "TODO" tags
dotnet_diagnostic.S1144.severity = warning       # Unused private fields (genuinely useful)
dotnet_diagnostic.S1172.severity = suggestion    # Unused method parameters
dotnet_diagnostic.S1450.severity = suggestion    # Field should be local variable
dotnet_diagnostic.S1481.severity = warning       # Unused local variables (genuinely useful)
dotnet_diagnostic.S1699.severity = warning       # Overridable method called from constructor
dotnet_diagnostic.S2325.severity = suggestion    # Make method static
dotnet_diagnostic.S3218.severity = suggestion    # Inner class members should not shadow outer
dotnet_diagnostic.S3267.severity = suggestion    # Use LINQ Where instead of loops
dotnet_diagnostic.S3358.severity = suggestion    # Nested ternary operations
dotnet_diagnostic.S3881.severity = suggestion    # IDisposable pattern conformance
dotnet_diagnostic.S3925.severity = suggestion    # Update ISerializable implementation
dotnet_diagnostic.S3928.severity = suggestion    # Parameter names in ArgumentException
dotnet_diagnostic.S4136.severity = suggestion    # Method overloads should be adjacent
dotnet_diagnostic.S6610.severity = suggestion    # Use char overload of StartsWith/EndsWith

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  IDE code style (enforced in build)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Prefer file-scoped namespaces
csharp_style_namespace_declarations = file_scoped:suggestion

# Prefer expression bodies for simple members
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_accessors = true:suggestion

# var preferences
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

# using directives
csharp_using_directive_placement = outside_namespace:suggestion

# Unused parameters
dotnet_code_quality_unused_parameters = all:suggestion
